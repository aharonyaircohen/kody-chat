{
  "name": "@kody-ade/kody-chat",
  "version": "0.1.0",
  "license": "MIT",
  "description": "Kody Chat — multi-tenant branded client chat product and embeddable chat platform",
  "repository": {
    "type": "git",
    "url": "https://github.com/aharonyaircohen/kody-chat.git"
  },
  "files": [
    "src",
    "app"
  ],
  "exports": {
    "./platform": "./src/dashboard/lib/chat/platform/index.ts",
    "./platform/lazy-panel": "./src/dashboard/lib/chat/platform/lazy-panel.tsx",
    "./platform/*": "./src/dashboard/lib/chat/platform/*.ts",
    "./core/*": "./src/dashboard/lib/chat/core/*.ts",
    "./core/transports/*": "./src/dashboard/lib/chat/core/transports/*.ts",
    "./plugins/*": "./src/dashboard/lib/chat/plugins/*/index.ts",
    "./components/KodyChat": "./src/dashboard/lib/components/KodyChat.tsx",
    "./components/*": "./src/dashboard/lib/components/*.tsx",
    "./components/ChatShell": "./src/dashboard/lib/components/ChatShell.tsx",
    "./components/Sidebar": "./src/dashboard/lib/components/Sidebar.tsx",
    "./components/PluginPanel": "./src/dashboard/lib/components/PluginPanel.tsx",
    "./auth-guard": "./src/dashboard/lib/auth-guard.tsx",
    "./client-brand": "./src/dashboard/lib/client-brand.ts"
  },
  "scripts": {
    "dev": "next dev --turbopack -p 3344",
    "build": "next build",
    "start": "next start -p 3344",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:int": "vitest run tests/int",
    "test:smoke": "node tests/smoke/run-smoke.mjs",
    "test:e2e": "playwright test",
    "test:e2e:local": "PW_LOCAL=1 BASE_URL=http://127.0.0.1:3344 playwright test --project=chromium",
    "test:gate": "pnpm test:unit && pnpm test:int && pnpm test:smoke && pnpm test:e2e:local",
    "vault:init": "node scripts/generate-vault-key.mjs",
    "push:init": "node scripts/generate-vapid-keys.mjs"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.77",
    "@ai-sdk/mcp": "^1.0.30",
    "@ai-sdk/openai-compatible": "^2.0.47",
    "@mintplex-labs/piper-tts-web": "^1.0.4",
    "@monaco-editor/react": "^4.7.0",
    "@octokit/plugin-throttling": "^11.0.3",
    "@octokit/rest": "^22.0.1",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.0.4",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.0.2",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-slot": "^1.0.2",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-query": "^5.90.21",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "ai": "^6.0.97",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "dompurify": "^3.4.11",
    "geist": "^1.3.0",
    "highlight.js": "^11.11.1",
    "jose": "^6.1.3",
    "libsodium-wrappers": "^0.8.4",
    "lucide-react": "^0.562.0",
    "mermaid": "^11.15.0",
    "mongodb": "^7.5.0",
    "next": "16.2.9",
    "next-auth": "5.0.0-beta.31",
    "node-pty": "^1.1.0",
    "pino": "^10.1.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "shiki": "^4.2.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "tailwindcss-animate": "^1.0.7",
    "web-push": "^3.6.7",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@next/eslint-plugin-next": "^16.2.9",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.1.18",
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^22.5.4",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/web-push": "^3.6.4",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "@vitest/coverage-v8": "^4.0.16",
    "autoprefixer": "^10.4.19",
    "dotenv": "^17.4.2",
    "eslint": "^9.16.0",
    "eslint-config-next": "15.4.7",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "nock": "^14.0.13",
    "pino-pretty": "^13.1.3",
    "playwright-core": "^1.58.2",
    "postcss": "^8.4.38",
    "prettier": "^3.4.2",
    "tailwindcss": "^4.1.18",
    "typescript": "5.9.3",
    "vitest": "4.0.16"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "node-pty"
    ]
  }
}
