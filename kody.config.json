{
  "$schema": "https://raw.githubusercontent.com/aharonyaircohen/Kody-Engine-Lite/main/kody.config.schema.json",
  "quality": {
    "typecheck": "pnpm typecheck",
    "lint": "pnpm lint",
    "format": "pnpm format:check",
    "testUnit": "pnpm test"
  },
  "git": {
    "defaultBranch": "main"
  },
  "github": {
    "owner": "aharonyaircohen",
    "repo": "Kody-Dashboard"
  },
  "agent": {
    "model": "minimax/MiniMax-M3"
  },
  "jobs": {
    "stateBackend": "contents-api"
  },
  "company": {
    "activeGoals": [
      "codebase-health",
      "ci-health"
    ],
    "activeAgents": [
      "ceo"
    ],
    "activeAgentResponsibilities": [
      "agent-responsibility-call"
    ],
    "activeAgentActions": [
      "agent-ask"
    ]
  },
  "agent-actions": {
    "default": "run"
  },
  "access": {
    "allowedAssociations": [
      "OWNER",
      "COLLABORATOR",
      "CONTRIBUTOR",
      "FIRST_TIME_CONTRIBUTOR",
      "MEMBER"
    ]
  },
  "defaultAgentAction": "classify",
  "defaultPrAgentAction": "fix",
  "agentActions": {
    "default": "run"
  },
  "state": {
    "repo": "https://github.com/aharonyaircohen/kody-state",
    "path": "Kody-Dashboard"
  }
}
