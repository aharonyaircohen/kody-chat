{
  "$schema": "https://raw.githubusercontent.com/aharonyaircohen/Kody-Engine-Lite/main/kody.config.schema.json",
  "quality": {
    "typecheck": "pnpm typecheck",
    "lint": "pnpm lint",
    "format": "pnpm format:check",
    "testUnit": "pnpm test"
  },
  "git": {
    "defaultBranch": "main"
  },
  "github": {
    "owner": "aharonyaircohen",
    "repo": "Kody-Dashboard"
  },
  "agent": {
    "model": "minimax/MiniMax-M3"
  },
  "jobs": {
    "stateBackend": "contents-api"
  },
  "company": {
    "activeGoals": [
      "codebase-health",
      "ci-health",
      "prs-stay-mergeable",
      "cms-content-editing",
      "web-release"
    ],
    "activeAgents": [
      "ceo"
    ],
    "activeCapabilities": [
      "capability-call",
      "cms-content-editor",
      "dev-ci-health"
    ],
    "activeExecutables": [
      "agent-ask"
    ]
  },
  "access": {
    "allowedAssociations": [
      "OWNER",
      "COLLABORATOR",
      "CONTRIBUTOR",
      "FIRST_TIME_CONTRIBUTOR",
      "MEMBER"
    ]
  },
  "defaultExecutable": "classify",
  "defaultPrExecutable": "fix",
  "state": {
    "repo": "https://github.com/aharonyaircohen/kody-state",
    "path": "Kody-Dashboard",
    "branch": "main"
  }
}