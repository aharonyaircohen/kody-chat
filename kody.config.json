{
  "$schema": "https://raw.githubusercontent.com/aharonyaircohen/kody-engine/main/kody.config.schema.json",
  "quality": {
    "typecheck": "pnpm typecheck",
    "lint": "pnpm lint",
    "testUnit": "pnpm test:unit"
  },
  "git": {
    "defaultBranch": "main"
  },
  "github": {
    "owner": "aharonyaircohen",
    "repo": "kody-chat",
    "operators": [
      "aguyaharonyair"
    ]
  },
  "agent": {
    "model": "minimax/MiniMax-M3"
  },
  "jobs": {
    "stateBackend": "contents-api"
  },
  "company": {
    "activeAgents": [
      "ceo",
      "cto",
      "coo"
    ],
    "activeCapabilities": [
      "company-portfolio-management",
      "agency-portfolio-management",
      "agency-operations-management",
      "ai-agency-health-matrix",
      "repo-source-health",
      "observe-repo-ci",
      "operate-findings",
      "dev-ci-health",
      "ceo-performance-review"
    ],
    "activeGoals": [
      {
        "template": "company-growth-loop",
        "every": "15m"
      },
      {
        "template": "agency-evolution-loop",
        "every": "15m"
      },
      {
        "template": "agency-operations-loop",
        "every": "15m"
      },
      {
        "template": "agency-observer",
        "every": "15m"
      },
      {
        "template": "agency-operating-loop",
        "every": "15m"
      }
    ]
  },
  "access": {
    "allowedAssociations": [
      "OWNER",
      "MEMBER",
      "COLLABORATOR"
    ]
  },
  "defaultExecutable": "classify",
  "defaultPrExecutable": "fix",
  "state": {
    "repo": "https://github.com/aharonyaircohen/kody-state",
    "path": "kody-chat",
    "branch": "main"
  }
}