# ===========================================
# REQUIRED — Auth / Sessions
# ===========================================

# Random secret for signing JWT sessions (e.g. openssl rand -hex 32)
KODY_SESSION_SECRET=your_session_secret_here

# Bot token for token-only auth (no GitHub OAuth needed)
# Used by: API routes, E2E tests (KODY_BOT_TOKEN secret)
KODY_BOT_TOKEN=your_bot_token_here

# ===========================================
# REQUIRED — GitHub API
# ===========================================

# GitHub Personal Access Token (or GitHub App token)
# Get from: https://github.com/settings/tokens
# Needs: repo, workflows scopes
GITHUB_TOKEN=your_github_token_here

# GitHub repo owner and name
GITHUB_OWNER=your_github_username
GITHUB_REPO=your_repo_name

# ===========================================
# REQUIRED — Chat (GitHub Actions + Kody Engine)
# ===========================================

# Chat is routed through GitHub Actions + Kody Engine (Claude Code).
# No Gemini API key needed — the engine handles AI.
# See: /api/kody/chat/trigger and /api/kody/events/stream

# Optional: engine repo for chat workflow (defaults to the connected repo
# from login auth; set this only if you want to centralize chat on one repo)
# KODY_CHAT_WORKFLOW_REPO=owner/repo
# KODY_CHAT_WORKFLOW_ID=kody2.yml

# ===========================================
# OPTIONAL
# ===========================================

# Public server URL (used for OAuth redirect and remote dev)
# In production, set this to your deployed URL (e.g. https://kody-dashboard.vercel.app)
NEXT_PUBLIC_SERVER_URL=http://localhost:3333

# GitHub PAT (alternative to GITHUB_TOKEN — MCP prefers this)
# GH_PAT=your_github_pat_here

# Figma API key (for Figma MCP — system architect only)
# FIGMA_API_KEY=your_figma_api_key
