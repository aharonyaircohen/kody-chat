{
  "manifest_version": 3,
  "name": "Kody Preview Inspector",
  "version": "0.4.3",
  "description": "Inspect a Kody preview: pick elements, send console errors, failed requests, screenshots into Kody chat as context.",
  "host_permissions": ["<all_urls>"],
  "background": {
    "scripts": ["src/background.js"]
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "all_frames": true,
      "run_at": "document_start",
      "js": ["src/content.js"]
    },
    {
      "matches": ["<all_urls>"],
      "all_frames": true,
      "run_at": "document_start",
      "world": "MAIN",
      "js": ["src/collector.js"]
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "kody-preview-inspector@kody-dashboard.local",
      "data_collection_permissions": {
        "required": ["websiteActivity", "websiteContent"]
      }
    }
  }
}
