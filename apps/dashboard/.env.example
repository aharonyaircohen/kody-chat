# ===========================================
# REQUIRED — Auth / Sessions
# ===========================================

# Random secret for signing JWT sessions (e.g. openssl rand -hex 32)
KODY_SESSION_SECRET=your_session_secret_here

# Bot token for token-only auth (no GitHub OAuth needed)
# Used by: API routes, E2E tests (KODY_BOT_TOKEN secret)
KODY_BOT_TOKEN=your_bot_token_here

# ===========================================
# REQUIRED — GitHub API
# ===========================================

# GitHub Personal Access Token (or GitHub App token)
# Get from: https://github.com/settings/tokens
# Needs: repo, workflows scopes
GITHUB_TOKEN=your_github_token_here

# GitHub repo owner and name
GITHUB_OWNER=your_github_username
GITHUB_REPO=your_repo_name

# Optional: comma-separated GitHub logins that count as "assigned to Kody"
# for dashboard visibility. Defaults to "kody".
# KODY_ASSIGNEE_LOGINS=kody

# ===========================================
# REQUIRED — Chat (GitHub Actions + Kody Engine)
# ===========================================

# Chat is routed through GitHub Actions + Kody Engine (Claude Code).
# No chat-model API key needed — the engine handles AI.
# See: /api/kody/chat/trigger and /api/kody/events/stream

# Optional: engine repo for chat workflow (defaults to the connected repo
# from login auth; set this only if you want to centralize chat on one repo)
# KODY_CHAT_WORKFLOW_REPO=owner/repo
# KODY_CHAT_WORKFLOW_ID=kody.yml

# Optional: repo whose brand registry serves public /client/<slug> pages.
# Client visitors have no dashboard cookie, so without this only builtin
# brands resolve for them.
# KODY_CLIENT_BRAND_REPO=owner/repo

# ===========================================
# OPTIONAL
# ===========================================

# ===========================================
# OPTIONAL — Local Brain server (dev only)
# ===========================================
#
# Point the dashboard's `brain` and `brain-fly` chat agents at a Brain
# server running on this machine. The matching `BRAIN_API_KEY` env var
# must also be set in the shell that runs `pnpm brain:local` (the script
# does NOT read it from .env).
#
#   Terminal 1: BRAIN_API_KEY=local-dev-key pnpm brain:local
#   Terminal 2: pnpm dev   (with BRAIN_CHAT_URL + BRAIN_CHAT_API_KEY below)
#
BRAIN_CHAT_URL=http://localhost:8080
BRAIN_CHAT_API_KEY=local-dev-key

# Optional: restrict the Brain server's working tree (default: cwd)
# BRAIN_REPOS_ROOT=/path/to/repos

# Public server URL (used for OAuth redirect and remote dev)
# In production, set this to your deployed URL (e.g. https://kody-dashboard.vercel.app)
NEXT_PUBLIC_SERVER_URL=http://localhost:3333

# GitHub PAT (alternative to GITHUB_TOKEN — MCP prefers this)
# GH_PAT=your_github_pat_here

# Figma API key (for Figma MCP — system architect only)
# FIGMA_API_KEY=your_figma_api_key

# ===========================================
# E2E / CI
# ===========================================

# Real-system chat e2e (tests/e2e/chat-real-system.spec.ts) — nightly only.
# Set all three in GitHub repo secrets for the nightly cron job to run.
# E2E_GITHUB_TOKEN=ghp_pat_with_repo_and_workflow_scopes
# E2E_GITHUB_REPO=https://github.com/owner/repo-with-kody.yml
# E2E_CHAT_MODEL=minimax/MiniMax-M2.7-highspeed

# Guard flag — tests stay skipped unless this is "1".
# RUN_REAL_E2E=1
