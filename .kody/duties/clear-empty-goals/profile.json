    "tools": ["Read", "Write", "Edit", "Bash", "Grep", "Glob"],
    "hooks": [],
    "skills": [],
    "commands": [],
    "subagents": [],
    "plugins": [],
    "mcpServers": []
  },
  "cliTools": [],
  "scripts": {
    "preflight": [{ "script": "loadIssueContext" }, { "script": "composePrompt" }],
    "postflight": [{ "script": "parseAgentResult" }, { "script": "postAgentComment" }]
  }
}
