{
  "name": "task-leader",
  "describe": "Task Leader",
  "action": "task-leader",
  "executable": "task-leader",
  "every": "15m",
  "staff": "kody",
  "runner": "kody",
  "readyPreviewCap": "15",
  "smallChangeMaxLines": "200",
  "smallChangeMaxFiles": "20",
  "staleReviewHours": "4",
  "blockAutoMergeLabel": "status:needs-review",
  "dispatchComment": "@kody",
  "tripwirePaths": {
    "item": [
      "db/",
      "migrations/",
      "prisma/",
      "schema/",
      "models/",
      ".github/",
      "Dockerfile",
      "package.json",
      "auth/",
      "middleware/"
    ]
  }
}
