{
  "name": "company-graph",
  "role": "primitive",
  "kind": "oneshot",
  "describe": "Derive the company orchestration graph from .kody files and refresh .kody/reports/company-graph.md.",
  "inputs": [],
  "claudeCode": {
    "model": "inherit",
    "permissionMode": "default",
    "maxTurns": 0,
    "maxThinkingTokens": null,
    "systemPromptAppend": null,
    "cacheable": true,
    "tools": [],
    "hooks": [],
    "skills": ["company-graph"],
    "commands": [],
    "subagents": [],
    "plugins": [],
    "mcpServers": []
  },
  "cliTools": [
    {
      "name": "gh",
      "install": {
        "required": true,
        "checkCommand": "gh --version"
      },
      "verify": "gh auth status",
      "usage": "Read repository metadata for the company graph report.",
      "allowedUses": [
        "read repository data"
      ]
    },
    {
      "name": "jq",
      "install": {
        "required": true,
        "checkCommand": "jq --version"
      },
      "verify": "jq --version",
      "usage": "Parse JSON while refreshing the company graph report.",
      "allowedUses": [
        "parse local command output"
      ]
    }
  ],
  "scripts": {
    "preflight": [
      { "script": "buildSyntheticPlugin" },
      { "shell": "refresh-company-graph.sh" },
      { "script": "skipAgent" }
    ],
    "postflight": []
  },
  "output": {
    "actionTypes": ["COMPANY_GRAPH_REFRESHED", "COMPANY_GRAPH_FAILED", "AGENT_NOT_RUN"]
  }
}
