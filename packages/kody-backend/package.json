{
  "name": "@kody-ade/backend",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "description": "Kody Convex backend \u2014 schema, functions, and import/export tooling. Deployable independently; the dashboard connects via CONVEX_URL when migration happens.",
  "exports": {
    "./client": "./src/client.ts",
    "./escape-keys": "./src/escape-keys.ts",
    "./table-registry": "./src/table-registry.ts",
    "./definition-bundle": "./src/definition-bundle.ts",
    "./api": "./convex/_generated/api.js"
  },
  "scripts": {
    "dev": "convex dev",
    "deploy": "convex deploy && vitest run --project smoke",
    "deploy:prod": "convex deploy --yes && vitest run --project smoke",
    "codegen": "convex codegen",
    "test:smoke": "vitest run --project smoke",
    "import:convex": "tsx scripts/import-convex.ts",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@kody-ade/agency-domain": "workspace:*",
    "convex": "^1.17.0"
  },
  "devDependencies": {
    "@edge-runtime/vm": "^5.0.0",
    "@types/node": "^22.5.4",
    "@vitest/coverage-v8": "4.0.16",
    "convex-test": "^0.0.54",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^4.0.16"
  },
  "type": "module"
}
