{
  "name": "@kody-ade/cms",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "description": "Kody CMS layer \u2014 collection config, storage adapters (state-repo + MongoDB), service, MCP surface, API route handlers, chat tools. Depends only on @kody-ade/base; consumed as TS source by both hosts.",
  "exports": {
    "./adapters": "./src/adapters/index.ts",
    "./adapters/*": "./src/adapters/*.ts",
    "./model/*": "./src/model/*.ts",
    "./schema/*": "./src/schema/*.ts",
    "./routes/*": "./src/routes/*.ts",
    "./tools/*": "./src/tools/*.ts",
    "./github": "./src/github.ts",
    "./*": "./src/*.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run"
  },
  "dependencies": {
    "@kody-ade/base": "workspace:*",
    "@octokit/rest": "^22.0.1",
    "ai": "^6.0.97",
    "mongodb": "^7.3.0",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "typescript": "5.9.3",
    "@types/react": "^19.2.17",
    "next": "16.2.9",
    "vitest": "^4.0.16"
  },
  "peerDependencies": {
    "react": "19.2.7",
    "next": "16.2.9"
  }
}
