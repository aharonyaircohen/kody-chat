  "scripts": {
    "dev": "next dev --turbopack -p 3344",
    "build": "next build",
    "build:library": "tsc -p library/tsconfig.json",
    "pack:library": "pnpm build:library && npm pack ./library",
    "test:external-package": "pnpm build:library && node scripts/verify-external-package.mjs",
    "start": "next start -p 3344",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:int": "vitest run tests/int",
    "test:smoke": "node tests/smoke/run-smoke.mjs",
    "test:e2e": "playwright test",
    "test:e2e:local": "PW_LOCAL=1 BASE_URL=http://127.0.0.1:3344 playwright test --project=chromium",
    "test:gate": "pnpm test:unit && pnpm test:int && pnpm test:smoke && pnpm test:e2e:local",
    "vault:init": "node scripts/generate-vault-key.mjs"
  },
